# Environment variables required to boot the app.
# Copy this file to `.env` and fill in values for non-Docker runs.
# Docker Compose users: values in `docker-compose.yml` take precedence; this
# file is just the contract / reference list.
#
# Generate fresh secrets with:  openssl rand -hex 32

# ─── Required (app won't boot without these) ──────────────────────────

# Pepper mixed into SHA256 when hashing merchant API keys for storage.
# Rotating this invalidates every merchant's API key (treat like a master key).
API_KEY_PEPPER=replace_me_with_openssl_rand_hex_32

# Signs the short-lived SDK session tokens (ActiveSupport::MessageVerifier).
# Rotating this invalidates every active session token (15-min impact window).
SDK_JWT_SIGNING_KEY=replace_me_with_openssl_rand_hex_32

# Rails 8 Active Record Encryption — encrypts merchants.hmac_secret at rest.
# Generate the trio once via `bin/rails db:encryption:init` and copy the output here.
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=replace_me_with_openssl_rand_hex_32
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=replace_me_with_openssl_rand_hex_32
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=replace_me_with_openssl_rand_hex_32

# ─── Database ─────────────────────────────────────────────────────────
# All optional with localhost defaults — only set if your Postgres isn't local.

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=
DATABASE_NAME=widget_platform_development
DATABASE_NAME_TEST=widget_platform_test

# Production only — used by config/database.yml.
# WIDGET_PLATFORM_DATABASE_PASSWORD=

# ─── Redis (Action Cable + Sidekiq + Rails cache) ─────────────────────

REDIS_URL=redis://localhost:6379/1

# ─── Rails server ─────────────────────────────────────────────────────

# RAILS_ENV=development
# PORT=3000
# RAILS_MAX_THREADS=5
# WEB_CONCURRENCY=1
# RAILS_LOG_LEVEL=info       # production-only
